{
  "info": {
    "name": "E-commerce Historias de Café - Payment Flow",
    "description": "Colección para probar el flujo Product -> Order -> Payment con Mercado Pago.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080",
      "type": "string"
    },
    {
      "key": "userId",
      "value": "1",
      "type": "string"
    },
    {
      "key": "productId",
      "value": "",
      "type": "string"
    },
    {
      "key": "orderId",
      "value": "",
      "type": "string"
    },
    {
      "key": "paymentId",
      "value": "",
      "type": "string"
    },
    {
      "key": "paymentUrl",
      "value": "",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "1. Users",
      "item": [
        {
          "name": "List users",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Users response is successful', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200]);",
                  "});",
                  "const users = pm.response.json();",
                  "if (Array.isArray(users) && users.length > 0 && users[0].id) {",
                  "    pm.collectionVariables.set('userId', users[0].id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Create user",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Prueba\",\n  \"email\": \"usuario.prueba@example.com\",\n  \"passwordHash\": \"password123\",\n  \"role\": \"cliente\",\n  \"stateActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('User created', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const user = pm.response.json();",
                  "if (user.id) {",
                  "    pm.collectionVariables.set('userId', user.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get user by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Update user",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Usuario Actualizado\",\n  \"email\": \"usuario.actualizado@example.com\",\n  \"passwordHash\": \"password123\",\n  \"role\": \"cliente\",\n  \"stateActive\": true\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          }
        },
        {
          "name": "Delete user",
          "request": {
            "method": "DELETE",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/users/{{userId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "users",
                "{{userId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "2. Products",
      "item": [
        {
          "name": "Create product",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"Café Especial\",\n  \"description\": \"Café molido premium\",\n  \"price\": 25000,\n  \"stock\": 10,\n  \"categorieId\": 1\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Product created', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const product = pm.response.json();",
                  "if (product.id) {",
                  "    pm.collectionVariables.set('productId', product.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List products",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products"
              ]
            }
          }
        },
        {
          "name": "Get product by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/products/{{productId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "products",
                "{{productId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "3. Orders",
      "item": [
        {
          "name": "Create order",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"userId\": {{userId}},\n  \"stateOrder\": \"PENDING\",\n  \"details\": [\n    {\n      \"productId\": {{productId}},\n      \"quantityProducts\": 2\n    }\n  ]\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Order created', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const order = pm.response.json();",
                  "if (order.id) {",
                  "    pm.collectionVariables.set('orderId', order.id);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "List orders",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders"
              ]
            }
          }
        },
        {
          "name": "Get order by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/orders/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "orders",
                "{{orderId}}"
              ]
            }
          }
        }
      ]
    },
    {
      "name": "4. Payments",
      "item": [
        {
          "name": "Create payment preference",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"orderId\": {{orderId}}\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/payments",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments"
              ]
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Payment preference created', function () {",
                  "    pm.expect(pm.response.code).to.be.oneOf([200, 201]);",
                  "});",
                  "const payment = pm.response.json();",
                  "if (payment.id) {",
                  "    pm.collectionVariables.set('paymentId', payment.id);",
                  "}",
                  "if (payment.paymentUrl) {",
                  "    pm.collectionVariables.set('paymentUrl', payment.paymentUrl);",
                  "    console.log('Open paymentUrl:', payment.paymentUrl);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Get payment by id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments/{{paymentId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "{{paymentId}}"
              ]
            }
          }
        },
        {
          "name": "Get payment by order id",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments/order/{{orderId}}",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "order",
                "{{orderId}}"
              ]
            }
          }
        },
        {
          "name": "Approve payment manually",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments/{{paymentId}}/status?status=APPROVED&transactionNumber=MP-123456",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "{{paymentId}}",
                "status"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "APPROVED"
                },
                {
                  "key": "transactionNumber",
                  "value": "MP-123456"
                }
              ]
            }
          }
        },
        {
          "name": "Reject payment manually",
          "request": {
            "method": "PATCH",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/payments/{{paymentId}}/status?status=REJECTED&transactionNumber=MP-REJECTED-123456",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "payments",
                "{{paymentId}}",
                "status"
              ],
              "query": [
                {
                  "key": "status",
                  "value": "REJECTED"
                },
                {
                  "key": "transactionNumber",
                  "value": "MP-REJECTED-123456"
                }
              ]
            }
          }
        }
      ]
    }
  ]
}
